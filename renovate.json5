{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  labels: [
    "kind/enhancement",
  ],
  "postUpdateOptions": [
    "gomodTidy"
  ],
  "packageRules": [
    {
      "groupName": "otel-collector",
      "groupSlug": "otel-collector",
      "matchManagers": ["gomod"],
      "matchPackagePrefixes": ["go.opentelemetry.io/collector/"]
    }
  ]
}
